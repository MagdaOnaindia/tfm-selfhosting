# === Torre Local — Variables para docker/local-stack-complete.yml ===

# Contraseña del certificado del Agent (generada por generate-secrets.sh)
AGENT_CERT_PASSWORD=

# Admin API Key del Broker (debe coincidir con la del VPS)
# Se encuentra en docker/broker/.env -> ADMIN_API_KEY
ADMIN_API_KEY=

# URL pública del Broker para registrar dominios automáticamente
# Usa cualquier subdominio de tu dominio (Caddy lo enruta al Broker)
BROKER_ADMIN_URL=https://api.magdaselfhosting.com

# Identificador del Agent (debe coincidir con el de appsettings.Production.json)
AGENT_ID=my-agent

# GID del grupo docker en el host (para acceso al socket)
# Obtener con: getent group docker | cut -d: -f3
DOCKER_GID=999
